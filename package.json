{
  "name": "feral",
  "version": "0.1.0",
  "description": "Unleash Claude Code on a dedicated machine. Run a team of AI developers safely in dangerous mode, managed from Slack.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "bash scripts/setup.sh",
    "setup:macos": "bash scripts/setup-macos.sh",
    "db:reset": "rm -f data/state.db && tsx src/db/migrate.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "discord.js": "^14.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dynobyte-labs/feral"
  },
  "keywords": [
    "claude",
    "claude-code",
    "feral",
    "orchestrator",
    "ai-agents",
    "multi-agent",
    "dangerous-mode"
  ]
}
