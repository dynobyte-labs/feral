# =============================================================================
# Feral — Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Authentication ---

# WORKERS: Run `claude login` on the command line for worker authentication.
# This uses your Claude Pro/Max subscription, so Claude Code worker usage is
# included in your plan at no extra cost.
#
# CHAT BOT (natural language mode): Set ANTHROPIC_API_KEY to enable the
# conversational Slack interface. Without it, you'll need to use !commands.
# The NLU layer uses claude-sonnet for intent parsing (~cheap, fast).
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Chat Bot (pick one or both) ---

# Slack bot token (xoxb-...) and app token (xapp-...)
# Create at: https://api.slack.com/apps
# SLACK_SIGNING_SECRET is not needed — Feral uses Socket Mode.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Your Slack member ID — auto-invited to every new project channel.
# Find it: click your profile pic → Profile → ⋯ → Copy member ID
SLACK_OWNER_ID=

# --- GitHub ---

# GitHub CLI (gh) uses this for repo creation
# Create at: https://github.com/settings/tokens (fine-grained recommended)
GITHUB_TOKEN=
GITHUB_ORG=              # Leave blank for personal repos

# --- Image Generation (optional) ---

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# --- Server ---

# Dashboard port
PORT=3000

# Where projects live on disk
PROJECTS_DIR=~/projects

# Max concurrent active workers (adjust for your RAM)
MAX_WORKERS=4

# --- Logging ---

LOG_LEVEL=info            # debug | info | warn | error
