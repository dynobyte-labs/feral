# =============================================================================
# Feral — Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Authentication ---

# PREFERRED: Run `claude login` on the command line instead of using an API key.
# This authenticates via your Claude Pro/Max subscription, which means Claude Code
# usage is included in your plan at no extra cost. Leave ANTHROPIC_API_KEY blank
# if using `claude login`.
#
# FALLBACK: If you prefer API key auth (billed per-token), set this:
ANTHROPIC_API_KEY=

# --- Chat Bot (pick one or both) ---

# Slack bot token (xoxb-...) and app token (xapp-...)
# Create at: https://api.slack.com/apps
# SLACK_SIGNING_SECRET is not needed — Feral uses Socket Mode.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- GitHub ---

# GitHub CLI (gh) uses this for repo creation
# Create at: https://github.com/settings/tokens (fine-grained recommended)
GITHUB_TOKEN=
GITHUB_ORG=              # Leave blank for personal repos

# --- Image Generation (optional) ---

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# --- Server ---

# Dashboard port
PORT=3000

# Where projects live on disk
PROJECTS_DIR=~/projects

# Max concurrent active workers (adjust for your RAM)
MAX_WORKERS=4

# --- Logging ---

LOG_LEVEL=info            # debug | info | warn | error
