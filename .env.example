# =============================================================================
# Feral — Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Required ---

# Anthropic API key for Claude Code workers
ANTHROPIC_API_KEY=sk-ant-...

# --- Chat Bot (pick one or both) ---

# Slack bot token (xoxb-...) and app token (xapp-...)
# Create at: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord bot token (optional alternative to Slack)
# Create at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# --- GitHub ---

# GitHub CLI (gh) uses this for repo creation
# Create at: https://github.com/settings/tokens (fine-grained recommended)
GITHUB_TOKEN=
GITHUB_ORG=              # Leave blank for personal repos

# --- Image Generation (optional) ---

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# --- Server ---

# Dashboard port
PORT=3000

# Where projects live on disk
PROJECTS_DIR=~/projects

# Max concurrent active workers (adjust for your RAM)
MAX_WORKERS=4

# --- Logging ---

LOG_LEVEL=info            # debug | info | warn | error
